{
  "name": "voltstation-app",
  "version": "1.0.0",
  "description": "VoltStation — solar-aware EV charging booking platform with auth",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "seed": "node src/seed.js",
    "refresh": "node src/refresh.js",
    "optimizer:demo": "python optimizer/solve_schedule.py < optimizer/sample_input.json",
    "check": "node --check server.js && node --check src/dayAheadOptimizer.js && python -m py_compile optimizer/solve_schedule.py",
    "test:optimizer": "python -m unittest optimizer/test_optimizer.py",
    "test:pricing": "node test/pricing.test.js",
    "test:load-data": "node scripts/validate_load_data.js"
  },
  "engines": { "node": ">=18" },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.0",
    "socket.io": "^4.8.1"
  }
}
