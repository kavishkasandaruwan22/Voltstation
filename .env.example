# Copy this file to ".env" and adjust if needed.

# MongoDB connection (local install or MongoDB Atlas connection string)
# MONGODB_URI=mongodb://127.0.0.1:27017/voltstation
MONGODB_URI=mongodb+srv://kavishkasandaruwan22:suLlaa0sgO4wfcL7@fyp.tppy7dy.mongodb.net/voltstation?retryWrites=true&w=majority
# Port the backend listens on
PORT=4000

# Use the real PVGIS API for solar (true) or the built-in modelled curve (false).
# Leave false for offline demos; set true when the machine has internet.
USE_PVGIS=false

# Solar data source for the forecast:
#   model     = built-in modelled curve (offline, scales with PV size)   [default]
#   pvgis     = PVGIS typical-year AC output (needs internet; a baseline, not a live forecast)
#   openmeteo = Open-Meteo REAL tomorrow forecast (needs internet; free, no API key)
SOLAR_SOURCE=model

# Building load: put your real values in  data/building_load.csv  (time,load_kW).
# If that file exists it is used automatically; otherwise a modelled curve is used.
