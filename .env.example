# Copy this file to ".env" and adjust for your machine.

# MongoDB connection. Use a local MongoDB URI or your own Atlas URI.
MONGODB_URI=mongodb://127.0.0.1:27017/voltstation
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/<database>?retryWrites=true&w=majority

# Optional local fallback if the primary URI is unavailable.
MONGODB_FALLBACK_LOCAL=false
MONGODB_LOCAL_URI=mongodb://127.0.0.1:27017/voltstation

# Port the backend listens on.
PORT=4000

# IANA timezone of the physical station, used to derive "today"/"tomorrow" dates
# (forecast refresh, booking date validation, optimizer). Do not rely on the
# server host's local clock, since it may run in a different timezone.
STATION_TZ=Asia/Colombo

# Solar data source for the forecast:
#   model     = built-in modelled curve (offline, scales with PV size)
#   pvgis     = PVGIS typical-year AC output (needs internet; a baseline, not a live forecast)
#   openmeteo = Open-Meteo real tomorrow forecast (needs internet)
SOLAR_SOURCE=model
